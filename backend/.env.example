# ============================================================
# Sanjeevani AI — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# From Supabase → Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# From Supabase → Settings → API → service_role key (NOT the anon key)
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here

# From console.groq.com → API Keys → Create key
GROQ_API_KEY=your-groq-api-key-here

# App environment: development | production
APP_ENV=development

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Random secret key for internal use (any long random string)
SECRET_KEY=change-this-to-a-long-random-secret-in-production

# Set to false to skip YOLO image detection (faster startup, no GPU needed)
YOLO_ENABLED=true

# YOLOv8 model size: yolov8n.pt (fast) | yolov8s.pt (better accuracy)
YOLO_MODEL=yolov8n.pt
